# Optional multimodal provider configuration. Configure only providers you intend to use.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=

# Provider safety limits used by agent-review generation.
DESIGN_REVIEW_PROVIDER_TIMEOUT_MS=120000
DESIGN_REVIEW_PROVIDER_MAX_OUTPUT_TOKENS=16384

# Optional local storage and loopback UI controls.
DESIGN_REVIEW_AUDIT_ROOT=audit-reports
DESIGN_REVIEW_MAX_CONCURRENT_JOBS=2
DESIGN_REVIEW_MAX_RETAINED_JOBS=200
HOST=127.0.0.1
PORT=5173
